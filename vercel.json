{
  "services": {
    "frontend": {
      "root": "frontend/",
      "framework": "create-react-app"
    },
    "backend": {
      "root": "backend/",
      "entrypoint": "server.py"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": { "service": "backend" }
    },
    {
      "source": "/(.*)",
      "destination": { "service": "frontend" }
    }
  ]
}
